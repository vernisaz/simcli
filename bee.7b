# build the simple CLI crate
crate  =simcli
crate main=lib
dep_crates=[] # [--extern, simcli]
comp opts=[]
crate_src=.
test file=test
common =..${~/~}simscript${~/~}comm-crate.7b:file
common_test =..${~/~}simscript${~/~}comm-test.7b:file
crate_dir=..${~/~}crates
doc_dir=..${~/~}docs

version=1.03
set_env(VERSION,version)

include(common);
include(common_test);